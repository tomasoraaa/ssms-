<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lgs.mapper.ModifyRequestMapper">

    <select id="selectAll" resultType="com.lgs.entity.ModifyRequest">
        select * from modify_request
        <where>
            <if test="userType != null and userType != ''"> and userType = #{userType}</if>
            <if test="status != null"> and status = #{status}</if>
        </where>
        order by createTime desc
    </select>

    <insert id="insert" parameterType="com.lgs.entity.ModifyRequest" useGeneratedKeys="true">
        insert into modify_request(id, userId, userName, userType, fieldName, oldValue, newValue, status, createTime)
        values (#{id}, #{userId}, #{userName}, #{userType}, #{fieldName}, #{oldValue}, #{newValue}, #{status}, NOW())
    </insert>

    <update id="updateById" parameterType="com.lgs.entity.ModifyRequest">
        update modify_request
        <set>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Integer">
        delete from modify_request where id = #{id}
    </delete>

    <select id="selectById" resultType="com.lgs.entity.ModifyRequest">
        select * from modify_request where id = #{id}
    </select>

</mapper>