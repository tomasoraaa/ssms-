<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lgs.mapper.ModifyRequestMapper">

    <select id="selectAll" resultType="com.lgs.entity.ModifyRequest">
        select * from modify_request
        <where>
            <if test="user_type != null and user_type != ''"> and user_type = #{user_type}</if>
            <if test="status != null"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insert" parameterType="com.lgs.entity.ModifyRequest" useGeneratedKeys="true">
        insert into modify_request(id, user_id, user_name, user_type, field_name, old_value, new_value, status, create_time)
        values (#{id}, #{user_id}, #{user_name}, #{user_type}, #{field_name}, #{old_value}, #{new_value}, #{status}, NOW())
    </insert>

    <update id="updateById" parameterType="com.lgs.entity.ModifyRequest">
        update modify_request
        <set>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Integer">
        delete from modify_request where id = #{id}
    </delete>

    <select id="selectById" resultType="com.lgs.entity.ModifyRequest">
        select * from modify_request where id = #{id}
    </select>

</mapper>