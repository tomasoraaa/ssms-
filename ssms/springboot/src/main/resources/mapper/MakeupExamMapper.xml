<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lgs.mapper.MakeupExamMapper">
    <resultMap id="MakeupExamResultMap" type="com.lgs.entity.MakeupExam">
        <id property="id" column="id"/>
        <result property="student_id" column="student_id"/>
        <result property="course_id" column="course_id"/>
        <result property="teaching_class_id" column="teaching_class_id"/>
        <result property="exam_type" column="exam_type"/>
        <result property="makeup_score" column="makeup_score"/>
        <result property="status" column="status"/>
        <result property="reason" column="reason"/>
        <result property="created_at" column="created_at"/>
        <result property="updated_at" column="updated_at"/>
    </resultMap>

    <select id="selectAll" resultMap="MakeupExamResultMap">
        SELECT * FROM makeup_exam
        <where>
            <if test="student_id != null">AND student_id = #{student_id}</if>
            <if test="course_id != null">AND course_id = #{course_id}</if>
            <if test="teaching_class_id != null">AND teaching_class_id = #{teaching_class_id}</if>
            <if test="exam_type != null">AND exam_type = #{exam_type}</if>
            <if test="status != null">AND status = #{status}</if>
        </where>
    </select>

    <select id="selectById" resultMap="MakeupExamResultMap">
        SELECT * FROM makeup_exam WHERE id = #{id}
    </select>

    <select id="selectByStudentId" resultMap="MakeupExamResultMap">
        SELECT * FROM makeup_exam WHERE student_id = #{student_id}
    </select>

    <select id="selectByCourseId" resultMap="MakeupExamResultMap">
        SELECT * FROM makeup_exam WHERE course_id = #{course_id}
    </select>

    <select id="selectByTeachingClassId" resultMap="MakeupExamResultMap">
        SELECT * FROM makeup_exam WHERE teaching_class_id = #{teaching_class_id}
    </select>

    <insert id="insert" parameterType="com.lgs.entity.MakeupExam">
        INSERT INTO makeup_exam (student_id, course_id, teaching_class_id, exam_type, makeup_score, status, reason)
        VALUES (#{student_id}, #{course_id}, #{teaching_class_id}, #{exam_type}, #{makeup_score}, #{status}, #{reason})
    </insert>

    <update id="updateById" parameterType="com.lgs.entity.MakeupExam">
        UPDATE makeup_exam
        <set>
            <if test="student_id != null">student_id = #{student_id},</if>
            <if test="course_id != null">course_id = #{course_id},</if>
            <if test="teaching_class_id != null">teaching_class_id = #{teaching_class_id},</if>
            <if test="exam_type != null">exam_type = #{exam_type},</if>
            <if test="makeup_score != null">makeup_score = #{makeup_score},</if>
            <if test="status != null">status = #{status},</if>
            <if test="reason != null">reason = #{reason},</if>
            updated_at = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM makeup_exam WHERE id = #{id}
    </delete>
</mapper>