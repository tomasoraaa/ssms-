<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lgs.mapper.CourseWithdrawalMapper">

    <insert id="insert" parameterType="com.lgs.entity.CourseWithdrawal" useGeneratedKeys="true">
        insert into course_withdrawal(studentId, courseId, teacherId, teacherName, reason, status)
        values (#{studentId}, #{courseId}, #{teacherId}, #{teacherName}, #{reason}, #{status})
    </insert>

    <select id="selectAll" resultType="com.lgs.entity.CourseWithdrawal">
        select * from course_withdrawal
        <where>
            <if test="studentId != null and studentId != ''"> and studentId = #{studentId}</if>
            <if test="courseId != null and courseId != ''"> and courseId = #{courseId}</if>
            <if test="status != null"> and status = #{status}</if>
        </where>
        order by withdrawalTime desc
    </select>

    <select id="selectByStudentId" parameterType="java.lang.String" resultType="com.lgs.entity.CourseWithdrawal">
        select * from course_withdrawal where studentId = #{studentId}
        order by withdrawalTime desc
    </select>

    <update id="updateById" parameterType="com.lgs.entity.CourseWithdrawal">
        update course_withdrawal
        <set>
            <if test="status != null">status = #{status}</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Integer">
        delete from course_withdrawal where id = #{id}
    </delete>

</mapper>